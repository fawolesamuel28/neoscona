# Normalize line endings: text files are stored LF in the repo. This collapses
# the phantom CRLF/LF churn that the Windows (WSL / /mnt/c) working tree
# otherwise produces — the root cause of the recurring "file corrupted by
# script" / full-file-rewrite diffs in this project's history.
* text=auto eol=lf
*.sh text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary
