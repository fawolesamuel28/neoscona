# ─── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Comma-separated dashboard origins in prod, e.g. https://app.reva.ng,https://reva.ng
# Leave blank/"*" in dev (serves a non-credentialed wildcard + logs a warning).
ALLOWED_ORIGINS=*
# Expose /docs and /redoc in production (hidden by default when ENVIRONMENT=production).
DOCS_ENABLED=false

# ─── Auth (Phase 1) ───────────────────────────────────────────────────────────
# Token verification:
#  • New projects use asymmetric JWT signing keys (ES256/RS256). No secret needed —
#    the backend verifies against the project's public JWKS, derived from
#    SUPABASE_URL as {SUPABASE_URL}/auth/v1/.well-known/jwks.json.
#  • Legacy projects use a shared HS256 secret below (Settings → API → JWT Secret).
# Set SUPABASE_JWT_SECRET only if you are still on the legacy shared secret.
SUPABASE_JWT_SECRET=
# Optional: override the JWKS endpoint (defaults to {SUPABASE_URL}/auth/v1/.well-known/jwks.json).
SUPABASE_JWKS_URL=
# Local-dev ONLY: bypass auth and inject an owner principal for DEFAULT_TENANT_ID.
# Ignored when ENVIRONMENT=production.
AUTH_DISABLED=false
# Cross-subdomain SSO cookies (set in production for .neoscona.xyz).
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ─── Meta WhatsApp Cloud API (Phase 3 Native) ──────────────────────────────────
# Reva can natively use Meta's Graph API, eliminating the need for 3rd party wrappers.
WHATSAPP_CLOUD_VERIFY_TOKEN=your_secure_webhook_passphrase_here
WHATSAPP_CLOUD_TOKEN=EAABv...
WHATSAPP_CLOUD_PHONE_ID=1234567890123

# ─── Evolution API / WhatsApp ─────────────────────────────────────────────────
# Leave blank to run in dev mode (messages logged to console instead of sent)
EVOLUTION_API_KEY=
EVOLUTION_BASE_URL=https://api.evolution.local
WHATSAPP_EVOLUTION_INSTANCE=Reva
WHATSAPP_EVOLUTION_API_KEY=your_evolution_global_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Connect your WhatsApp Business API or 360dialog (Optional fallback)────────────────────────────────────────────────────────────
# Options: gemini | ollama | anthropic
LLM_PROVIDER=gemini

# ─── Google Gemini (cloud, recommended for Telegram) ─────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Ollama (local) ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── Anthropic / Claude (cloud) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
# Anon/public key — safe to expose to the browser. Served via GET /api/config so
# the dashboard can initialize Supabase Auth. Falls back to SUPABASE_KEY.
SUPABASE_ANON_KEY=
# Prefer service role for server writes (dashboard import, upsert); falls back to SUPABASE_KEY
SUPABASE_SERVICE_KEY=
# Tenant for leads/conversation_logs (defaults to seeded Atlantic Horizons UUID)
DEFAULT_TENANT_ID=a0000000-0000-4000-8000-000000000001
# Optional — run scripts/apply_migration.py without using SQL editor
SUPABASE_DB_PASSWORD=
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── WhatsApp webhook security ───────────────────────────────────────────────
EVOLUTION_WEBHOOK_SECRET=

# ─── Calendly (site visit booking) ───────────────────────────────────────────
CALENDLY_API_TOKEN=
CALENDLY_EVENT_URL=

# ─── Admin (inventory API, optional) ─────────────────────────────────────────
ADMIN_API_KEY=

# ─── Billing / Flutterwave (Phase 2, NGN)
# Replace Paystack with Flutterwave: set these in your environment for production.
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
FLUTTERWAVE_CALLBACK_URL=
# Legacy Paystack env (kept for historical DB columns; safe to remove later):
# PAYSTACK_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=
# PAYSTACK_PLAN_STARTER=
# PAYSTACK_PLAN_GROWTH=
# PAYSTACK_CALLBACK_URL=
# Free-trial length (days) and enforcement mode.
#   soft  = meter usage only, never block (default — safe).
#   hard  = block AI replies once a tenant is over its message quota.
# A 'canceled' subscription always hard-stops replies regardless of this setting.
TRIAL_DAYS=14
BILLING_ENFORCEMENT=soft

# ─── Inbox / human takeover (Phase 3) ────────────────────────────────────────
# Minutes a taken-over lead can wait on an unanswered inbound before the SLA timer
# nudges the team (dashboard badge + WhatsApp ping to the assigned agent).
INBOX_SLA_MINUTES=10